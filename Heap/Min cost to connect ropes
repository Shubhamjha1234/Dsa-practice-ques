class Solution {
    public static int minCost(int[] arr) {
     int cost = 0;
     PriorityQueue<Integer> pq= new PriorityQueue<>();
     
     for(int ele :arr){
         pq.add(ele);
     }
     while(pq.size()>1){
       int fst = pq.remove();
       int snd = pq.remove();
        cost += fst+snd;
       pq.add(fst+snd);
     }
     return cost;
     
        
    }
}
